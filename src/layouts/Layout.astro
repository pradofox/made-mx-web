---
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/dm-mono/400.css';
import '~/styles/tokens.css';
import '~/styles/global.css';

import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'MADE — México Art & Design Exhibition',
  description = 'Plataforma cultural de Monterrey que conecta arte, diseño y ciudad. MADE Week, MADE Work y proyectos culturales para empresas.',
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicons/favicon-dark.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicons/favicon-light.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
