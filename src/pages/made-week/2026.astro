---
import Layout from '~/layouts/Layout.astro';

const stats = [
  { num: '10', label: 'Días' },
  { num: '+70', label: 'Eventos' },
  { num: '+80', label: 'Espacios' },
  { num: '+7,000', label: 'Asistencias' },
  { num: '7', label: 'Circuitos' },
  { num: '50+', label: 'Voluntarios' },
];

const reach = [
  { num: '9,428', label: 'Seguidores Instagram' },
  { num: '21.8%', label: 'Engagement rate' },
  { num: '+1.3M', label: 'Vistas en Instagram' },
  { num: '160.5k', label: 'Cuentas alcanzadas' },
];

const circuits = [
  'Casco Urbano',
  'Centrito Valle',
  'Garza Sada',
  'Obispado',
  'MTY Centro',
  'Tampiquito',
  'Cordillera',
];

const sponsors = [
  'Heineken',
  'Tec de Monterrey · EAAD',
  'SlimPop',
  'Los Patrones',
  'Salón Reina',
  'Impresos Sifer',
  'Sound&Vision',
  'Rumba Rebel',
  'Laboratorio Arte AC',
  'Lyto',
];

const venues = [
  'Museo MARCO',
  'CONARTE',
  'LABNL',
  'Tec de Monterrey',
  'UDEM',
  'LCI Monterrey',
  'Brands & People',
  'Cadena Concepts',
  'Dreaming Studio',
  'Narrativo Studio',
  'Weyes Studio',
  'Zanni Creative House',
  'MAD Arq Studio',
];

const gallery = [
  '/img/mw26/hero-01.jpg',
  '/img/mw26/hero-02.jpg',
  '/img/mw26/hero-03.jpg',
  '/img/mw26/hero-04.jpg',
  '/img/mw26/hero-05.jpg',
  '/img/mw26/hero-06.jpg',
  '/img/mw26/hero-07.jpg',
  '/img/mw26/hero-08.jpg',
];
---

<Layout
  title="MADE Week 2026 — 10 días, +70 eventos, +7,000 personas"
  description="MW26 pasó por 7 circuitos de Monterrey con +70 eventos y +7,000 asistencias. Esto fue lo que vivimos."
>
  <section class="hero">
    <div class="container">
      <span class="mono-label mono-label--ink">MW26 · 19 FEB - 1 MAR 2026 · Archivo</span>
      <h1 class="hero__title">10 días.<br />+70 eventos.<br />+7,000 personas.</h1>
      <p class="hero__lede">
        Pasamos por 7 circuitos de la ciudad. Esto fue lo que vivimos.
      </p>
    </div>
  </section>

  <section class="cover">
    <img src="/img/mw26/hero-01.jpg" alt="Comunidad MADE Week 2026 en Adoro" loading="eager" />
  </section>

  <section class="stats">
    <div class="container">
      <span class="mono-label mono-label--ink">Resumen</span>
      <h2 class="stats__heading">Lo que pasó en febrero.</h2>
      <div class="stats__grid">
        {stats.map(({ num, label }) => (
          <div class="stat">
            <span class="stat__num">{num}</span>
            <span class="mono-label">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="reach">
    <div class="container">
      <span class="mono-label mono-label--ink">Alcance digital</span>
      <h2 class="reach__heading">Engagement real,<br />no audiencia inflada.</h2>
      <div class="reach__grid">
        {reach.map(({ num, label }) => (
          <div class="reach__item">
            <span class="reach__num">{num}</span>
            <span class="mono-label">{label}</span>
          </div>
        ))}
      </div>
      <p class="reach__note">
        21.8% de engagement es 7 a 20 veces el promedio de la industria. Cuando MADE recomienda algo, la gente lo ve.
      </p>
    </div>
  </section>

  <section class="gallery">
    <div class="container container--wide">
      <div class="gallery__grid">
        {gallery.map((src, i) => (
          <figure class={`gallery__cell gallery__cell--${i + 1}`}>
            <img src={src} alt={`MADE Week 2026, momento ${i + 1}`} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="circuits">
    <div class="container">
      <span class="mono-label mono-label--ink">7 Circuitos</span>
      <h2 class="circuits__heading">La ciudad,<br />en circuitos caminables.</h2>
      <ul class="circuits__list">
        {circuits.map((c, i) => (
          <li class="circuits__item">
            <span class="mono-label">0{i + 1}</span>
            <span class="circuits__name">{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="sponsors">
    <div class="container">
      <span class="mono-label mono-label--ink">Patrocinadores y aliados</span>
      <h2 class="sponsors__heading">Marcas que apostaron por la cultura.</h2>
      <ul class="sponsors__list">
        {sponsors.map((s) => <li>{s}</li>)}
      </ul>
    </div>
  </section>

  <section class="venues">
    <div class="container">
      <span class="mono-label mono-label--ink">Espacios destacados</span>
      <h2 class="venues__heading">Donde se vivió.</h2>
      <ul class="venues__list">
        {venues.map((v) => <li>{v}</li>)}
      </ul>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <span class="mono-label mono-label--ink">Lo que viene</span>
      <h2 class="cta__title">MW27<br />ya se cocina.</h2>
      <p class="cta__lede">
        Suscríbete al newsletter para enterarte de la agenda antes que nadie. ¿Eres marca? Tenemos esquemas de patrocinio listos.
      </p>
      <div class="cta__actions">
        <a href="/newsletter" class="cta__btn cta__btn--primary">Suscribirme al newsletter →</a>
        <a href="/empresas" class="cta__btn cta__btn--ghost">Patrocinar MW27 →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: clamp(60px, 10vh, 140px) clamp(40px, 6vh, 80px);
  }
  .hero__title {
    font-size: var(--text-hero);
    line-height: var(--lh-tight);
    letter-spacing: var(--tr-display);
    margin-block: 24px 32px;
  }
  .hero__lede {
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: 36ch;
  }

  .cover {
    padding: 0;
  }
  .cover img {
    width: 100%;
    height: clamp(360px, 64vh, 720px);
    object-fit: cover;
    display: block;
  }

  .stats {
    background: var(--bg-alt);
  }
  .stats__heading {
    font-size: var(--text-2xl);
    margin-block: 16px 40px;
    max-width: 18ch;
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px 24px;
    border-top: 1px solid var(--made-line);
    padding-top: 32px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat__num {
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--made-blue);
  }

  .reach {
    background: var(--made-blue);
    color: var(--made-bg);
  }
  .reach :global(.mono-label),
  .reach :global(.mono-label--ink) {
    color: color-mix(in oklab, var(--made-bg) 75%, transparent);
  }
  .reach :global(.mono-label--ink) {
    color: var(--made-bg);
  }
  .reach__heading {
    color: var(--made-bg);
    font-size: var(--text-2xl);
    margin-block: 16px 40px;
  }
  .reach__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px 24px;
    border-top: 1px solid color-mix(in oklab, var(--made-bg) 25%, transparent);
    padding-top: 32px;
  }
  .reach__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .reach__num {
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--made-bg);
  }
  .reach__note {
    margin-top: 32px;
    max-width: 60ch;
    font-size: var(--text-lg);
    color: color-mix(in oklab, var(--made-bg) 88%, transparent);
  }

  .gallery {
    padding-block: clamp(40px, 6vh, 80px);
  }
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-auto-rows: minmax(180px, 28vh);
    gap: 8px;
  }
  .gallery__cell {
    margin: 0;
    overflow: hidden;
  }
  .gallery__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--t-slow) var(--ease-out);
  }
  .gallery__cell:hover img {
    transform: scale(1.03);
  }
  .gallery__cell--1 { grid-column: 1 / span 4; grid-row: 1 / span 2; }
  .gallery__cell--2 { grid-column: 5 / span 2; }
  .gallery__cell--3 { grid-column: 7 / span 2; }
  .gallery__cell--4 { grid-column: 5 / span 4; }
  .gallery__cell--5 { grid-column: 1 / span 3; }
  .gallery__cell--6 { grid-column: 4 / span 3; }
  .gallery__cell--7 { grid-column: 7 / span 2; }
  .gallery__cell--8 { grid-column: 1 / span 8; grid-row: span 1; }

  .circuits__heading,
  .sponsors__heading,
  .venues__heading {
    font-size: var(--text-2xl);
    margin-block: 16px 40px;
    max-width: 22ch;
  }

  .circuits__list {
    list-style: none;
    padding: 0;
    display: grid;
    border-top: 1px solid var(--made-line);
  }
  .circuits__item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    padding: 24px 0;
    align-items: baseline;
    border-bottom: 1px solid color-mix(in oklab, var(--fg) 20%, transparent);
  }
  .circuits__name {
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .sponsors {
    background: var(--bg-alt);
  }
  .sponsors__list,
  .venues__list {
    list-style: none;
    padding: 0;
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .sponsors__list li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tr-mono-label);
    padding: 14px 22px;
    background: var(--bg);
    border: 1px solid var(--made-line);
  }
  .venues__list li {
    font-size: var(--text-base);
    padding: 10px 18px;
    background: var(--bg-alt);
  }

  .cta {
    background: var(--made-ink);
    color: var(--made-bg);
  }
  .cta :global(.mono-label--ink) {
    color: var(--made-bg);
  }
  .cta__title {
    color: var(--made-bg);
    font-size: var(--text-3xl);
    margin-block: 16px 24px;
  }
  .cta__lede {
    color: color-mix(in oklab, var(--made-bg) 80%, transparent);
    font-size: var(--text-lg);
    max-width: 50ch;
    margin-bottom: 32px;
  }
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .cta__btn {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tr-mono-label);
    padding: 14px 24px;
  }
  .cta__btn--primary {
    background: var(--made-blue);
    color: var(--made-bg);
  }
  .cta__btn--ghost {
    border: 1px solid var(--made-bg);
  }

  @media (max-width: 900px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .reach__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(220px, 30vh);
    }
    .gallery__cell {
      grid-column: auto !important;
      grid-row: auto !important;
    }
    .circuits__item {
      grid-template-columns: 60px 1fr;
    }
  }
</style>
