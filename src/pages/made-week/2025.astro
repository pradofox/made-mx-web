---
import Layout from '~/layouts/Layout.astro';

const stats = [
  { num: '7', label: 'Días' },
  { num: '38', label: 'Eventos' },
  { num: '39', label: 'Sedes' },
  { num: '2,773', label: 'Asistentes' },
  { num: '46', label: 'Agentes' },
  { num: '17%', label: 'Engagement IG' },
];
---

<Layout
  title="MADE Week 2025 — La primera edición"
  description="MW25 fue la edición fundadora: 7 días, 38 eventos, 2,773 asistentes, 39 sedes y 46 agentes culturales."
>
  <section class="hero">
    <div class="container">
      <span class="mono-label mono-label--ink">MW25 · Primera edición · Archivo</span>
      <h1 class="hero__title">El experimento<br />que se volvió<br />comunidad.</h1>
      <p class="hero__lede">
        La primera edición de MADE Week. Un punto de partida, una prueba pública, una semilla.
      </p>
    </div>
  </section>

  <section class="stats">
    <div class="container">
      <span class="mono-label">Resumen</span>
      <div class="stats__grid">
        {stats.map(({ num, label }) => (
          <div class="stat">
            <span class="stat__num">{num}</span>
            <span class="mono-label">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: clamp(60px, 10vh, 140px) clamp(40px, 6vh, 80px);
  }
  .hero__title {
    font-size: var(--text-hero);
    line-height: var(--lh-tight);
    letter-spacing: var(--tr-display);
    margin-block: 24px 32px;
  }
  .hero__lede {
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: 36ch;
  }
  .stats {
    background: var(--bg-alt);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 32px 24px;
    margin-top: 32px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat__num {
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: 1;
  }
  @media (max-width: 720px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
