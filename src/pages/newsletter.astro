---
import Layout from '~/layouts/Layout.astro';
---

<Layout
  title="Newsletter — MADE"
  description="Una vez al mes. Cero ruido. Lo que pasa, lo que viene y a quién deberías estar siguiendo en la escena cultural de Monterrey."
>
  <section class="hero">
    <div class="container">
      <span class="mono-label mono-label--ink">Newsletter MADE</span>
      <h1 class="hero__title">Una vez al mes.<br />Cero ruido.</h1>
      <p class="hero__lede">
        Lo que pasa, lo que viene y a quién deberías estar siguiendo en la escena cultural de Monterrey. <strong>+1,000 personas</strong> ya están adentro.
      </p>

      <form class="form" action="#" method="post" data-form="newsletter">
        <label class="form__field">
          <span class="mono-label">Nombre</span>
          <input type="text" name="name" required autocomplete="given-name" />
        </label>
        <label class="form__field">
          <span class="mono-label">Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <button type="submit" class="form__submit">Suscribirme →</button>
        <p class="form__note">Pendiente conexión a Beehiiv. No envíes datos reales todavía.</p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: clamp(80px, 14vh, 200px) clamp(60px, 10vh, 140px);
  }
  .hero__title {
    font-size: var(--text-hero);
    line-height: var(--lh-tight);
    letter-spacing: var(--tr-display);
    margin-block: 24px 32px;
  }
  .hero__lede {
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: 42ch;
    margin-bottom: 48px;
  }
  .form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 480px;
  }
  .form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form__field input {
    border: 1px solid var(--fg);
    background: transparent;
    padding: 12px 16px;
    font-size: var(--text-base);
    border-radius: 0;
    transition: border-color var(--t-fast) var(--ease-out);
  }
  .form__field input:focus {
    outline: none;
    border-color: var(--made-blue);
  }
  .form__submit {
    margin-top: 8px;
    background: var(--made-ink);
    color: var(--made-bg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tr-mono-label);
    padding: 14px 24px;
    align-self: flex-start;
    transition: background var(--t-fast) var(--ease-out);
  }
  .form__submit:hover {
    background: var(--made-blue);
  }
  .form__note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-mute);
    margin-top: 8px;
  }
</style>
